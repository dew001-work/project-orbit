{
  "manifest_version": 3,
  "name": "Project Orbit",
  "description": "AI browser extension foundation for reading the current page context.",
  "version": "0.3.0",
  "action": {
    "default_title": "Project Orbit",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"]
}
